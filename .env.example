# ============================================================================
# Sentinel Stack — environment variables
# Copy this file to `.env` and fill in your values. NEVER commit `.env`.
# ============================================================================

# --- AWS (only if using YACE) ----------------------------------------------
# Prefer an instance IAM role over keys. Just set the region here.
AWS_REGION=us-east-1

# --- Chat notifications ------------------------------------------------------
# Incoming webhook for your chat platform (Google Chat, Slack, etc.)
CHAT_WEBHOOK_URL=

# --- On-call / paging --------------------------------------------------------
# Webhook for your on-call provider (iLert, PagerDuty events API, Opsgenie…).
# Used by alertmanager.yml for critical alerts.
ONCALL_WEBHOOK_URL=

# --- AI triage (optional) ----------------------------------------------------
ENABLE_AI_TRIAGE=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=8000

# --- GitHub issues (optional) ------------------------------------------------
# When the AI decides an alert is a real problem, open an issue here.
ENABLE_GITHUB_ISSUES=false
GITHUB_TOKEN=
GITHUB_REPO=owner/repo
